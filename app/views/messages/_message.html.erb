<% if message.role == 'assistant' %>
  <script>document.getElementById('temp-loader')?.remove();</script>
<% end %>

<div id="<%= dom_id(message) %>" class="flex gap-3 <%= 'flex-row-reverse' if message.role == 'user' %> animate-in fade-in duration-300">
  <div class="flex-shrink-0">
    <%= image_tag (message.role == 'user' ? 'user_icon.png' : 'letran_icon.png'), class: 'w-10 h-10 rounded-full object-cover' %>
  </div>
  <div class="<%= message.role == 'user' ? 'bg-blue-600 text-white' : 'bg-white/10 text-white border border-white/10' %> rounded-2xl px-4 py-3 max-w-2xl shadow-sm">
    <div class="text-sm prose prose-invert max-w-none">
      <% if message.role == 'assistant' %>
        <% if message.content.blank? %>

          <%#  NOTE: Loading dot animation here! %>
          <div class="flex gap-1 items-center py-1">
            <span class="w-2 h-2 bg-white/50 rounded-full animate-bounce" style="animation-delay: 0ms"></span>
            <span class="w-2 h-2 bg-white/50 rounded-full animate-bounce" style="animation-delay: 150ms"></span>
            <span class="w-2 h-2 bg-white/50 rounded-full animate-bounce" style="animation-delay: 300ms"></span>
          </div>
        <% else %>
          <% renderer = Redcarpet::Render::HTML.new(filter_html: true) %>
          <% markdown = Redcarpet::Markdown.new(renderer, autolink: true, fenced_code_blocks: true, tables: true) %>
          <%= markdown.render(message.content).html_safe %>
        <% end %>
      <% else %>
        <p class="whitespace-pre-wrap"><%= message.content %></p>
      <% end %>
    </div>
  </div>
</div>
